# ============================================
# EduSchedule - Variables d'Environnement (EXEMPLE)
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# === MYSQL CONFIGURATION ===
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=iusjcdb
MYSQL_USER=iusjc
MYSQL_PASSWORD=iusjc2024
MYSQL_HOST=mysql
MYSQL_PORT=3306

# === REDIS CONFIGURATION ===
REDIS_HOST=redis
REDIS_PORT=6379

# === RABBITMQ CONFIGURATION ===
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=iusjc
RABBITMQ_DEFAULT_PASS=iusjc2024

# === EUREKA CONFIGURATION ===
EUREKA_SERVER_HOST=eureka-server
EUREKA_SERVER_PORT=8761
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-server:8761/eureka/

# === API GATEWAY CONFIGURATION ===
API_GATEWAY_PORT=8080

# === FRONTEND CONFIGURATION ===
FRONTEND_PORT=8090

# === SPRING DATASOURCE CONFIGURATION ===
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/iusjcdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=iusjc
SPRING_DATASOURCE_PASSWORD=iusjc2024
SPRING_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver

# === JPA/HIBERNATE CONFIGURATION ===
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# === JWT CONFIGURATION (user-service) ===
# Générer une clé secrète forte pour la production
JWT_SECRET=your-secret-key-here-change-in-production
JWT_EXPIRATION=86400000

# === MAIL CONFIGURATION (notification-service) ===
# Configurer avec vos identifiants SMTP
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# === REDIS CACHE CONFIGURATION ===
SPRING_CACHE_TYPE=redis
REDIS_TTL=3600

# === RABBITMQ QUEUE CONFIGURATION ===
NOTIFICATION_QUEUE_NAME=notification-queue
NOTIFICATION_EXCHANGE_NAME=notification-exchange
NOTIFICATION_ROUTING_KEY=notification.#
SCHEDULE_QUEUE_NAME=schedule-notifications
SCHEDULE_EXCHANGE_NAME=schedule-exchange
SCHEDULE_ROUTING_KEY=schedule.#

# === LOGGING CONFIGURATION ===
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_CM_IUSJC=DEBUG

# === ACTUATOR CONFIGURATION ===
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics

# === DOCKER IMAGE TAGS ===
DOCKER_REGISTRY=darlene4
IMAGE_TAG=latest

# === ENT INTEGRATION CONFIGURATION ===
ENT_API_BASE_URL=http://localhost:9000
ENT_API_TIMEOUT=30000

# === ENVIRONMENT ===
SPRING_PROFILES_ACTIVE=dev
