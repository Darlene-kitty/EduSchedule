# ============================================
# EduSchedule - Variables d'Environnement (EXEMPLE)
# ============================================
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS commiter le fichier .env dans Git

# === DATABASE ===
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=iusjcdb
MYSQL_USER=iusjc
MYSQL_PASSWORD=changeme
MYSQL_HOST=localhost
MYSQL_PORT=3306

# === REDIS ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === RABBITMQ ===
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=iusjc
RABBITMQ_DEFAULT_PASS=changeme

# === EUREKA ===
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://localhost:8761/eureka/

# === SPRING DATASOURCE ===
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/iusjcdb?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=iusjc
SPRING_DATASOURCE_PASSWORD=changeme

# === JWT ===
# Générer avec: openssl rand -base64 64
JWT_SECRET=your-very-long-secret-key-here-minimum-32-chars
JWT_EXPIRATION=86400000

# === MAIL (Gmail) ===
# Utiliser un mot de passe d'application Gmail (pas votre mot de passe normal)
# https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-16-chars
MAIL_FROM=noreply@yourdomain.com

# === SMS (Twilio) — optionnel ===
SMS_TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_SENDER_ID=EduSchedule

# === DOCKER ===
DOCKER_IMAGE_PREFIX=darlene4/eduschedule
IMAGE_TAG=latest

# === FRONTEND ===
API_GATEWAY_URL=http://api-gateway:8080
WS_URL=ws://api-gateway:8080/ws

# === ENVIRONMENT ===
SPRING_PROFILES_ACTIVE=dev
