# Configuration Frontend EduSchedule
# Copiez ce fichier vers .env.local et ajustez selon vos besoins

# Port du serveur de développement Next.js
# Par défaut: 3000
# Vous pouvez utiliser n'importe quel port (3000, 3001, 3002, etc.)
PORT=3000

# URL de base de l'API Gateway
# En développement local
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# En production ou avec Docker
# NEXT_PUBLIC_API_BASE_URL=http://api-gateway:8080

# Avec Nginx
# NEXT_PUBLIC_API_BASE_URL=http://localhost/api

# Timeout des requêtes API (en millisecondes)
NEXT_PUBLIC_API_TIMEOUT=30000

# Mode de développement
NODE_ENV=development

# ============================================
# Exemples de Configuration
# ============================================

# Configuration pour port 3001
# PORT=3001
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Configuration pour Docker
# PORT=3000
# NEXT_PUBLIC_API_BASE_URL=http://api-gateway:8080

# Configuration avec Nginx reverse proxy
# PORT=3000
# NEXT_PUBLIC_API_BASE_URL=http://localhost

# Configuration pour GitHub Codespaces
# (détecté automatiquement dans api-config.ts)
# NEXT_PUBLIC_API_BASE_URL sera ajusté automatiquement
